@startuml
'https://plantuml.com/class-diagram
title 敌机工厂方法模式结构图 (Factory Method Pattern)

' ==========================================
' 【排版优化指令】
' ==========================================
' 使用正交线条（直角折线），消除杂乱的斜线
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 80

' ==========================================
' 客户端 (Client)
' ==========================================
class Game {
    - enemyAircrafts: List<AbstractEnemy>
    + action(): void
}

' ==========================================
' 抽象层 (Interfaces & Abstract Classes)
' ==========================================
interface EnemyFactory <<interface>> {
    + {abstract} createEnemy(): AbstractEnemy
}

abstract class AbstractEnemy {
    + AbstractEnemy(int locationX, int locationY, int speedX, int speedY, int hp)
    + forward(): void
    + {abstract} shoot(): List<BaseBullet>
    + {abstract} getScore(): int
    + {abstract} dropProps(): List<AbstractProp>
}

' 客户端依赖抽象层
Game ..> EnemyFactory
Game ..> AbstractEnemy

' ==========================================
' 具体工厂层 (Concrete Factories)
' ==========================================
class MobFactory {
    + createEnemy(): AbstractEnemy
}
class EliteFactory {
    + createEnemy(): AbstractEnemy
}
class ElitePlusFactory {
    + createEnemy(): AbstractEnemy
}
class BossFactory {
    + createEnemy(): AbstractEnemy
}

MobFactory .up.|> EnemyFactory
EliteFactory .up.|> EnemyFactory
ElitePlusFactory .up.|> EnemyFactory
BossFactory .up.|> EnemyFactory

' ==========================================
' 具体产品层 (Concrete Products)
' ==========================================
class MobEnemy {
    + MobEnemy(int locationX, int locationY, int speedX, int speedY, int hp)
    + getScore(): int
    + dropProps(): List<AbstractProp>
}
class EliteEnemy {
    + EliteEnemy(int locationX, int locationY, int speedX, int speedY, int hp)
    + getScore(): int
    + dropProps(): List<AbstractProp>
}
class ElitePlusEnemy {
    + ElitePlusEnemy(int locationX, int locationY, int speedX, int speedY, int hp)
    + getScore(): int
    + dropProps(): List<AbstractProp>
}
class BossEnemy {
    + BossEnemy(int locationX, int locationY, int speedX, int speedY, int hp)
    + getScore(): int
    + dropProps(): List<AbstractProp>
}

MobEnemy -up-|> AbstractEnemy
EliteEnemy -up-|> AbstractEnemy
ElitePlusEnemy -up-|> AbstractEnemy
BossEnemy -up-|> AbstractEnemy

' ==========================================
' 生产依赖关系 (Creates)
' ==========================================
' 工厂与对应产品建立虚线连接
MobFactory ..> MobEnemy : creates
EliteFactory ..> EliteEnemy : creates
ElitePlusFactory ..> ElitePlusEnemy : creates
BossFactory ..> BossEnemy : creates

@enduml